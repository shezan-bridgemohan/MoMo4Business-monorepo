{
  "name": "MoMo4Business-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.14.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:all": "turbo run build",
    "lint:all": "turbo run lint",
    "type-check:all": "turbo run type-check",
    "dev:all": "turbo run dev --parallel",
    "clean": "turbo run clean --continue",
    "clean:all": "turbo run clean --continue && rm -rf .turbo"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}