{
  "name": "@shared/ui-components",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared React UI component library for monorepo apps",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@shared/tokens": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "~6.0.2"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "clean": "rm -rf dist .turbo"
  }
}
